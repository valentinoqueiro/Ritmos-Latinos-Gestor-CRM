# Copiá este archivo a .env y completá los valores reales. NUNCA subas .env al repo.

# URL de conexión a Postgres.
# - Desarrollo local: postgresql://gestor:gestor@localhost:5432/gestor_dev
# - Producción (Neon): usar la URL "pooled" del proyecto, que incluye sslmode=require
DATABASE_URL=postgresql://gestor:gestor@localhost:5432/gestor_dev

# Secreto para firmar las sesiones (mínimo 32 caracteres).
# Generá uno con: openssl rand -base64 48
AUTH_SECRET=cambiame-por-un-secreto-largo-de-verdad-000000
